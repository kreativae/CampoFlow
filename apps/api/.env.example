DATABASE_URL="postgresql://campoflow:campoflow@localhost:5432/campoflow?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3100"
# 32-byte key, hex-encoded (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-64-hex-chars"

# Login com Google (OAuth2). Sem essas variaveis o botao "Entrar com Google" fica
# oculto no painel web e as rotas /auth/google* respondem 503. Veja como obter
# Client ID/Secret em docs/google-oauth-setup.md.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
# URL do painel web para onde o usuario e redirecionado apos o login no Google,
# com os tokens JWT na query string (consumido por /oauth/callback no Next.js).
WEB_OAUTH_REDIRECT_URL="http://localhost:3100/oauth/callback"

# Storage de arquivos (modulo Documentos). Sem essas variaveis, os arquivos ficam
# em disco local (apps/api/uploads) - ok para dev, nao recomendado em produção
# (perdido se o servidor for recriado). Veja docs/cloudflare-r2-setup.md.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# Envio de e-mail real (modulo Notificacoes). Sem RESEND_API_KEY, o resumo de
# alertas por e-mail fica registrado como SIMULATED em vez de SENT. Veja
# docs/resend-setup.md.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CampoFlow <notificacoes@seudominio.com>"

# Cobranca recorrente (modulo Billing/Conta-Assinatura) via Mercado Pago. Sem
# MERCADOPAGO_ACCESS_TOKEN, /conta/assinatura/checkout responde 400 (checkout
# self-service desabilitado), mas o resto do billing (trial, limite de fazendas,
# cancelamento) funciona normalmente. Use o access token de PRODUCAO (nao o de
# teste) para cobrar de verdade; o de teste é so para validar o fluxo no sandbox.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""
# URL do painel web para onde o pagador volta apos autorizar a assinatura no Mercado Pago.
# Em producao, deve ser https (ex: https://app.campoflow.com/conta/assinatura).
WEB_BILLING_REDIRECT_URL="http://localhost:3100/conta/assinatura"
# URL publica da API, usada para montar o endpoint do webhook do Mercado Pago.
API_PUBLIC_URL="http://localhost:3000"
# URL publica que o Mercado Pago deve chamar para notificar mudancas de status da
# assinatura (configurar no painel de developers do Mercado Pago):
#   https://sua-api.com/conta/assinatura/webhook/mercadopago

# Plataforma: e-mails (separados por virgula) que ganham acesso de admin da
# plataforma (rotas /admin/*) automaticamente ao se registrar ou logar com Google.
PLATFORM_ADMIN_EMAILS=""

# Observabilidade. Sem SENTRY_DSN, erros nao sao reportados (apenas logados no
# console) - normal em dev. Em produção, crie um projeto Node/NestJS em sentry.io
# e cole o DSN aqui.
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
# Fracao de requisicoes com tracing de performance habilitado (0 a 1). Comece baixo
# em produção; suba se precisar investigar lentidao.
SENTRY_TRACES_SAMPLE_RATE="0.1"

# URL do painel web para o link de redefinicao de senha enviado por e-mail.
WEB_PASSWORD_RESET_URL="http://localhost:3100/redefinir-senha"

# Formato dos logs no stdout. "json" emite uma linha JSON por log (recomendado em
# produção, para qualquer agregador de logs conseguir parsear); deixe vazio em dev
# para o output colorido padrao do Nest.
LOG_FORMAT=""

# URL do painel web para onde vai o link de convite de equipe (modulo Membros).
WEB_INVITE_URL="http://localhost:3100/convites/aceitar"
