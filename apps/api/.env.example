DATABASE_URL="postgresql://campoflow:campoflow@localhost:5432/campoflow?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3100"
# 32-byte key, hex-encoded (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-64-hex-chars"

# Login com Google (OAuth2). Sem essas variaveis o botao "Entrar com Google" fica
# oculto no painel web e as rotas /auth/google* respondem 503. Veja como obter
# Client ID/Secret em docs/google-oauth-setup.md.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
# URL do painel web para onde o usuario e redirecionado apos o login no Google,
# com os tokens JWT na query string (consumido por /oauth/callback no Next.js).
WEB_OAUTH_REDIRECT_URL="http://localhost:3100/oauth/callback"

# Storage de arquivos (modulo Documentos). Sem essas variaveis, os arquivos ficam
# em disco local (apps/api/uploads) - ok para dev, nao recomendado em produção
# (perdido se o servidor for recriado). Veja docs/cloudflare-r2-setup.md.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
