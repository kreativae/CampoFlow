// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}

enum Role {
  OWNER
  MANAGER
  VETERINARIAN
  EMPLOYEE
  CONSULTANT
}

model User {
  id                     String          @id @default(uuid())
  email                  String          @unique
  // Nullable because OAuth-only accounts (Google) never set a local password.
  passwordHash           String?
  name                   String
  // Set when the account was created/linked via "Entrar com Google".
  googleId               String?         @unique
  refreshTokenHash       String?
  mfaSecret              String?
  mfaEnabled             Boolean         @default(false)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  // Brute-force protection: incremented on each wrong password, reset on success.
  // After LOGIN_LOCKOUT_THRESHOLD failures, lockedUntil is set and login is refused
  // (even with the correct password) until it passes — see AuthService.login().
  failedLoginAttempts    Int             @default(0)
  lockedUntil            DateTime?
  // Billing account this user belongs to (created automatically at registration).
  // A user can still be added as a Membership/collaborator on farms owned by other
  // accounts (e.g. a veterinarian consulting for multiple clients) — accountId only
  // determines which subscription/plan this user's own farms are billed under.
  account                Account         @relation(fields: [accountId], references: [id])
  accountId              String
  ticketsCreated         Ticket[]        @relation("TicketCreatedBy")
  ticketMessages         TicketMessage[]
  // First user to register under an Account; can manage billing/plan and invite others.
  isAccountAdmin         Boolean         @default(true)
  // Platform staff (you/your team), not a customer role. Granted automatically at
  // registration if the e-mail is in PLATFORM_ADMIN_EMAILS (see AuthService.register).
  // Gates every /admin/* route via PlatformAdminGuard.
  isPlatformAdmin        Boolean         @default(false)
  memberships            Membership[]
  assignedTasks          Task[]          @relation("TaskAssignee")
  workLogs               WorkLog[]
  shifts                 Shift[]
  notifications          Notification[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

enum PlanTier {
  TRIAL
  BASICO
  PROFISSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

// Billing entity: owns N farms and one subscription/plan. Created automatically the
// moment the first user registers; additional users invited later join the same
// Account only if explicitly created under it (see AccountsService).
model Account {
  id           String        @id @default(uuid())
  name         String
  billingEmail String
  document     String?
  users        User[]
  farms        Farm[]
  subscription Subscription?
  tickets      Ticket[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// One-to-one with Account. planTier drives the farm-count limit enforced in
// FarmsService.create() (see PLAN_LIMITS in billing/plans.ts). status TRIALING/ACTIVE
// allow normal use; PAST_DUE/SUSPENDED/CANCELED block mutating requests outside of
// /conta/assinatura and /auth (see SubscriptionGuard).
model Subscription {
  id                       String             @id @default(uuid())
  account                  Account            @relation(fields: [accountId], references: [id])
  accountId                String             @unique
  planTier                 PlanTier           @default(TRIAL)
  status                   SubscriptionStatus @default(TRIALING)
  mercadoPagoPreapprovalId String?
  trialEndsAt              DateTime?
  currentPeriodEnd         DateTime?
  canceledAt               DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
}

enum FarmType {
  FAZENDA
  SITIO
  CHACARA
  CONFINAMENTO
  ARRENDAMENTO
}

model Farm {
  id                 String          @id @default(uuid())
  account            Account         @relation(fields: [accountId], references: [id])
  accountId          String
  name               String
  type               FarmType        @default(FAZENDA)
  totalAreaHectares  Float?
  usableAreaHectares Float?
  latitude           Float?
  longitude          Float?
  registryNumber     String?
  technicalManager   String?
  memberships        Membership[]
  invites            FarmInvite[]
  pastures           Pasture[]
  animals            Animal[]
  transactions       Transaction[]
  weatherRecords     WeatherRecord[]
  supplies           Supply[]
  machines           Machine[]
  tasks              Task[]
  workLogs           WorkLog[]
  shifts             Shift[]
  agendaEvents       AgendaEvent[]
  notifications      Notification[]
  mapFeatures        MapFeature[]
  documents          Document[]
  soilAnalyses       SoilAnalysis[]
  cropCycles         CropCycle[]
  cropApplications   CropApplication[]
  cropCostEntries    CropCostEntry[]
  contacts           Contact[]
  employees          Employee[]
  timeEntries        TimeEntry[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

// Pending invitation for someone who doesn't have an account yet. If the invited
// e-mail already belongs to a registered user, FarmsService.addMember() skips this
// entirely and creates the Membership immediately (existing behavior) — invites only
// exist to bridge "I want to add my vet/employee but they haven't signed up yet".
model FarmInvite {
  id          String    @id @default(uuid())
  farm        Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId      String
  email       String
  role        Role
  tokenHash   String
  invitedById String?
  // Módulos que o membro poderá acessar. Vazio = acesso total (conforme o papel).
  moduleAccess String[] @default([])
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([farmId])
}

model Membership {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  farmId    String
  role      Role
  // Módulos (páginas) que este membro pode acessar. Vazio = acesso total.
  moduleAccess String[] @default([])
  createdAt DateTime @default(now())

  @@unique([userId, farmId])
}

model Pasture {
  id             String              @id @default(uuid())
  farm           Farm                @relation(fields: [farmId], references: [id])
  farmId         String
  name           String
  areaHectares   Float
  grassType      String?
  animalCapacity Int
  occupations    PastureOccupation[]
  animals        Animal[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Tracks a batch of animals occupying a pasture between rotations (history of occupation).
model PastureOccupation {
  id        String    @id @default(uuid())
  pasture   Pasture   @relation(fields: [pastureId], references: [id], onDelete: Cascade)
  pastureId String
  headCount Int
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  notes     String?
}

enum AnimalSex {
  MALE
  FEMALE
}

enum AnimalCategory {
  BEZERRO
  BEZERRA
  NOVILHO
  NOVILHA
  GARROTE
  BOI
  VACA
  TOURO
  MATRIZ
}

model Animal {
  id                 String              @id @default(uuid())
  farm               Farm                @relation(fields: [farmId], references: [id])
  farmId             String
  pasture            Pasture?            @relation(fields: [pastureId], references: [id])
  pastureId          String?
  earTag             String
  rfid               String?
  name               String?
  sex                AnimalSex
  breed              String?
  category           AnimalCategory
  birthDate          DateTime?
  currentWeightKg    Float?
  active             Boolean             @default(true)
  events             AnimalEvent[]
  vaccinations       VaccinationRecord[]
  treatments         TreatmentRecord[]
  weighings          WeighingRecord[]
  reproductiveEvents ReproductiveEvent[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([farmId, earTag])
}

enum AnimalEventType {
  TRANSFER
  WEIGHING
  VACCINATION
  TREATMENT
  REPRODUCTIVE
  SALE
  DEATH
}

// Generic event log for an animal's history; specialized records (weighing, vaccination, etc.)
// reference their own row by id and reuse this table for unified timeline queries.
model AnimalEvent {
  id          String          @id @default(uuid())
  animal      Animal          @relation(fields: [animalId], references: [id])
  animalId    String
  type        AnimalEventType
  occurredAt  DateTime        @default(now())
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
}

model VaccinationRecord {
  id             String    @id @default(uuid())
  animal         Animal    @relation(fields: [animalId], references: [id])
  animalId       String
  vaccineName    String
  scheduledDate  DateTime
  administeredAt DateTime?
  batchNumber    String?
  administeredBy String?
  notes          String?
  createdAt      DateTime  @default(now())
}

model TreatmentRecord {
  id             String   @id @default(uuid())
  animal         Animal   @relation(fields: [animalId], references: [id])
  animalId       String
  diagnosis      String?
  medication     String
  dosage         String?
  treatmentDate  DateTime @default(now())
  administeredBy String?
  notes          String?
  createdAt      DateTime @default(now())
}

model WeighingRecord {
  id        String   @id @default(uuid())
  animal    Animal   @relation(fields: [animalId], references: [id])
  animalId  String
  weightKg  Float
  weighedAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
}

enum ReproductiveEventType {
  IATF
  MONTA_NATURAL
  INSEMINACAO
  DIAGNOSTICO_PRENHEZ
  PARTO
  ABORTO
}

enum PregnancyDiagnosisResult {
  PRENHE
  VAZIA
}

model ReproductiveEvent {
  id        String                    @id @default(uuid())
  animal    Animal                    @relation(fields: [animalId], references: [id])
  animalId  String
  type      ReproductiveEventType
  eventDate DateTime                  @default(now())
  result    PregnancyDiagnosisResult?
  notes     String?
  createdAt DateTime                  @default(now())
}

enum TransactionType {
  RECEITA
  DESPESA
}

enum TransactionCategory {
  NUTRICAO
  MEDICAMENTOS
  FUNCIONARIOS
  COMBUSTIVEL
  MAQUINARIO
  ENERGIA
  VENDA_ANIMAL
  OUTROS
}

model Transaction {
  id          String              @id @default(uuid())
  farm        Farm                @relation(fields: [farmId], references: [id])
  farmId      String
  type        TransactionType
  category    TransactionCategory
  description String?
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  cropCycle   CropCycle?          @relation(fields: [cropCycleId], references: [id], onDelete: SetNull)
  cropCycleId String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// Records who changed what: every mutating request (POST/PATCH/PUT/DELETE) gets one row.
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String?
  method     String
  path       String
  statusCode Int
  createdAt  DateTime @default(now())
}

enum Commodity {
  BOI_GORDO
  VACA_GORDA
  NOVILHA
  BEZERRO
  REPOSICAO
  COURO
  SEBO
  LEITE
  MILHO
  SOJA
  SORGO
  FARELO_SOJA
  MERCADO_FUTURO
  BOI_MUNDO
  ATACADO
  EQUIVALENTES
}

enum BrazilianState {
  AC
  AL
  AP
  AM
  BA
  CE
  DF
  ES
  GO
  MA
  MT
  MS
  MG
  PA
  PB
  PR
  PE
  PI
  RJ
  RN
  RS
  RO
  RR
  SC
  SP
  SE
  TO
}

// Market price reference data, shared across all farms (not tenant-scoped).
// state is null for national/aggregate quotes (e.g. the automatic Redação Agro feed)
// and set for manually entered regional quotes, mirroring how Scot Consultoria/CEPEA
// break down prices by state — those sources are commercial products without a public
// API (and CEPEA's robots.txt explicitly disallows AI crawlers), so this stays
// manual-entry only rather than scraped.
model Quotation {
  id          String          @id @default(uuid())
  commodity   Commodity
  state       BrazilianState?
  price       Float
  unit        String
  source      String?
  recordedAt  DateTime        @default(now())
  createdById String?
  createdAt   DateTime        @default(now())
}

// Farm-specific weather conditions. Auto-populated from Open-Meteo (free, no API key,
// CC BY 4.0) for farms with latitude/longitude set, on top of manual entry — see
// ExternalWeatherService. source is null for manually entered records.
model WeatherRecord {
  id              String   @id @default(uuid())
  farm            Farm     @relation(fields: [farmId], references: [id])
  farmId          String
  temperatureC    Float?
  humidityPercent Float?
  windSpeedKmh    Float?
  pressureHpa     Float?
  rainfallMm      Float?
  notes           String?
  source          String?
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
}

enum SupplyCategory {
  SAL_MINERAL
  RACAO
  FERTILIZANTE
  HERBICIDA
  DEFENSIVO
  OUTROS
}

enum SupplyMovementType {
  ENTRADA
  SAIDA
}

model Supply {
  id              String           @id @default(uuid())
  farm            Farm             @relation(fields: [farmId], references: [id])
  farmId          String
  name            String
  category        SupplyCategory
  // Free-text label shown instead of "Outros" when category is OUTROS — lets
  // the customer name their own category without expanding the fixed enum.
  customCategory  String?
  unit            String
  currentQuantity Float            @default(0)
  minimumQuantity Float            @default(0)
  expirationDate  DateTime?
  notes           String?
  movements       SupplyMovement[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// Stock entries/exits; Supply.currentQuantity is kept in sync transactionally on each movement.
model SupplyMovement {
  id         String             @id @default(uuid())
  supply     Supply             @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  supplyId   String
  type       SupplyMovementType
  quantity   Float
  notes      String?
  occurredAt DateTime           @default(now())
  createdAt  DateTime           @default(now())
}

enum MachineType {
  TRATOR
  CAMINHAO
  IMPLEMENTO
  OUTRO
}

model Machine {
  id               String               @id @default(uuid())
  farm             Farm                 @relation(fields: [farmId], references: [id])
  farmId           String
  name             String
  type             MachineType
  brand            String?
  model            String?
  year             Int?
  currentHourMeter Float                @default(0)
  notes            String?
  maintenances     MachineMaintenance[]
  fuelRecords      MachineFuelRecord[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

// Machine.currentHourMeter is kept in sync when a higher reading is reported here.
model MachineMaintenance {
  id          String   @id @default(uuid())
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  machineId   String
  description String
  cost        Float?
  hourMeterAt Float?
  performedAt DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

// Machine.currentHourMeter is kept in sync when a higher reading is reported here.
model MachineFuelRecord {
  id          String   @id @default(uuid())
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  machineId   String
  liters      Float
  cost        Float?
  hourMeterAt Float?
  recordedAt  DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model Task {
  id           String     @id @default(uuid())
  farm         Farm       @relation(fields: [farmId], references: [id])
  farmId       String
  title        String
  description  String?
  assignedTo   User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  status       TaskStatus @default(PENDENTE)
  dueDate      DateTime?
  completedAt  DateTime?
  workLogs     WorkLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Apontamento: hours a team member worked, optionally tied to a specific task.
model WorkLog {
  id          String   @id @default(uuid())
  farm        Farm     @relation(fields: [farmId], references: [id])
  farmId      String
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  task        Task?    @relation(fields: [taskId], references: [id])
  taskId      String?
  description String
  hoursWorked Float
  workDate    DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

// Escala: a team member's assigned working period.
model Shift {
  id        String   @id @default(uuid())
  farm      Farm     @relation(fields: [farmId], references: [id])
  farmId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
}

enum EmployeeType {
  EFETIVO
  CHAPA
  TEMPORARIO
  OUTRO
}

// Funcionário da equipe (não é um usuário do sistema): efetivos, chapas, temporários
// e outros. hourlyRate is the valor/hora used to cost this worker's logged hours.
model Employee {
  id          String       @id @default(uuid())
  farm        Farm         @relation(fields: [farmId], references: [id])
  farmId      String
  name        String
  type        EmployeeType @default(EFETIVO)
  role        String?
  document    String?
  phone       String?
  hourlyRate  Float        @default(0)
  active      Boolean      @default(true)
  notes       String?
  timeEntries TimeEntry[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Registro de horas / banco de horas de um funcionário. hours é positivo para horas
// trabalhadas/crédito e negativo para folga/débito, de modo que a soma é o saldo do
// banco de horas. O custo é derivado de horas positivas × hourlyRate do funcionário.
model TimeEntry {
  id          String   @id @default(uuid())
  farm        Farm     @relation(fields: [farmId], references: [id])
  farmId      String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String
  workDate    DateTime @default(now())
  hours       Float
  description String
  paid        Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
}

enum AgendaEventType {
  VACINACAO
  PESAGEM
  MANEJO
  COMPRA
  VENDA
  OUTRO
}

// General-purpose farm calendar. Vaccination/weighing already have dedicated flows
// elsewhere (health-records, weighings); this covers manejo/compra/venda and any
// ad-hoc reminder that doesn't have its own module.
model AgendaEvent {
  id            String          @id @default(uuid())
  farm          Farm            @relation(fields: [farmId], references: [id])
  farmId        String
  title         String
  type          AgendaEventType
  scheduledDate DateTime
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum MapFeatureType {
  CERCA
  PASTAGEM
  NASCENTE
  RESERVA
  OUTRO
}

enum GeometryType {
  PONTO
  POLIGONO
}

// Farm map features (cercas, pastagens, nascentes, reservas). Coordinates are stored as
// JSON: a single [lat, lng] pair for PONTO, or an array of [lat, lng] pairs for POLIGONO.
// Rendered client-side with Leaflet + OpenStreetMap (no API key required), since
// Google Maps/Mapbox would need paid API credentials not available in this environment.
model MapFeature {
  id           String         @id @default(uuid())
  farm         Farm           @relation(fields: [farmId], references: [id])
  farmId       String
  name         String
  type         MapFeatureType
  geometryType GeometryType
  coordinates  Json
  notes        String?
  soilAnalyses SoilAnalysis[]
  cropCycles   CropCycle[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// A single planting cycle ("safra") of a crop on a talhão (MapFeature), from planting
// through harvest. mapFeatureId is optional so a cycle can be registered before the
// talhão itself is mapped. Status is derived on read (not stored) from the three dates.
model CropCycle {
  id                String      @id @default(uuid())
  farm              Farm        @relation(fields: [farmId], references: [id])
  farmId            String
  mapFeature        MapFeature? @relation(fields: [mapFeatureId], references: [id], onDelete: SetNull)
  mapFeatureId      String?
  cropName          String
  variety           String?
  areaHectares      Float?
  plantedAt         DateTime
  expectedHarvestAt DateTime?
  harvestedAt       DateTime?
  yieldKg           Float?
  salePricePerUnit  Float?
  saleUnit          CropSaleUnit?
  notes             String?
  createdById       String?
  applications      CropApplication[]
  costEntries       CropCostEntry[]
  transactions      Transaction[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// Unidade de venda para calcular receita/produtividade no fechamento da safra.
enum CropSaleUnit {
  SACA60
  KG
  ARROBA
}

enum CropCostCategory {
  SEMENTE
  FERTILIZANTE
  DEFENSIVO
  CALCARIO
  OPERACAO
  MAO_DE_OBRA
  ARRENDAMENTO
  OUTRO
}

// Lançamento manual de custo de uma safra (para o fechamento).
model CropCostEntry {
  id          String           @id @default(uuid())
  farm        Farm             @relation(fields: [farmId], references: [id])
  farmId      String
  cropCycle   CropCycle        @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)
  cropCycleId String
  category    CropCostCategory
  description String
  amount      Float
  incurredAt  DateTime         @default(now())
  createdAt   DateTime         @default(now())
}

enum CropApplicationType {
  PLANTIO
  ADUBACAO
  CALAGEM
  HERBICIDA
  FUNGICIDA
  INSETICIDA
  DEFENSIVO
  IRRIGACAO
  OUTRO
}

// Caderno de campo: registro de operações/aplicações em uma safra (plantio,
// adubação, defensivos), com dose, carência e responsável.
model CropApplication {
  id                     String              @id @default(uuid())
  farm                   Farm                @relation(fields: [farmId], references: [id])
  farmId                 String
  cropCycle              CropCycle           @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)
  cropCycleId            String
  type                   CropApplicationType
  product                String
  dosePerHa              Float?
  doseUnit               String?
  totalQuantity          Float?
  unitPrice              Float?
  appliedAt              DateTime            @default(now())
  preHarvestIntervalDays Int?
  responsible            String?
  notes                  String?
  createdAt              DateTime            @default(now())
}

enum ContactType {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum ContactCategory {
  FORNECEDOR
  CLIENTE
  VETERINARIO
  TRANSPORTADOR
  COMPRADOR
  PRESTADOR_SERVICO
  OUTRO
}

// Contact book (suppliers, clients, vets, etc.), covering both pessoa física (CPF) and
// pessoa jurídica (CNPJ) — document is a free-text field validated client-side only,
// since CPF/CNPJ format differs and the value is informational, not used for lookups.
model Contact {
  id            String           @id @default(uuid())
  farm          Farm             @relation(fields: [farmId], references: [id])
  farmId        String
  type          ContactType
  category      ContactCategory  @default(OUTRO)
  name          String
  tradeName     String?
  document      String?
  email         String?
  phone         String?
  whatsapp      String?
  addressStreet String?
  addressCity   String?
  addressState  String?
  addressZip    String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

enum DocumentCategory {
  GTA
  NFE
  CONTRATO
  EXAME
  CERTIFICADO
  OUTRO
}

// File metadata; the binary itself is stored on local disk under apps/api/uploads
// (storagePath). A future iteration can swap this for AWS S3 / Cloudflare R2 without
// changing this model, since storagePath is just an opaque reference to the file.
model Document {
  id           String           @id @default(uuid())
  farm         Farm             @relation(fields: [farmId], references: [id])
  farmId       String
  category     DocumentCategory
  fileName     String
  mimeType     String
  fileSize     Int
  storagePath  String
  uploadedById String?
  notes        String?
  createdAt    DateTime         @default(now())
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  SIMULATED
  FAILED
}

enum NotificationSource {
  SANIDADE
  AGENDA
  INSUMOS
  CLIMA
  OUTRO
}

// In-app notifications are persisted and genuinely delivered (read/unread state below).
// EMAIL/SMS/PUSH have no real provider configured in this environment (no SendGrid/Twilio/
// FCM credentials available), so those channels are recorded with status SIMULATED instead
// of SENT — the record documents what *would* have been dispatched and to whom, without
// claiming a delivery that didn't happen. Swapping in a real provider later only requires
// changing NotificationsService.dispatch(), not this model.
model Notification {
  id        String              @id @default(uuid())
  farm      Farm                @relation(fields: [farmId], references: [id])
  farmId    String
  user      User                @relation(fields: [userId], references: [id])
  userId    String
  title     String
  message   String
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  source    NotificationSource  @default(OUTRO)
  read      Boolean             @default(false)
  readAt    DateTime?
  createdAt DateTime            @default(now())
}

// Soil lab analysis (analise de solo), optionally tied to an existing MapFeature
// (a drawn pasture/fence/spring/reserve area) so results are anchored to a place on
// the farm map instead of free text. Several analyses over time for the same
// mapFeatureId form the history/comparison series. documentPath is an opaque storage
// key (same StorageService used by the Documents module) for the uploaded lab PDF.
model SoilAnalysis {
  id                    String      @id @default(uuid())
  farm                  Farm        @relation(fields: [farmId], references: [id])
  farmId                String
  mapFeature            MapFeature? @relation(fields: [mapFeatureId], references: [id], onDelete: SetNull)
  mapFeatureId          String?
  areaLabel             String?
  collectedAt           DateTime
  ph                    Float?
  phosphorusMgDm3       Float?
  potassiumCmolcDm3     Float?
  calciumCmolcDm3       Float?
  magnesiumCmolcDm3     Float?
  aluminumCmolcDm3      Float?
  organicMatterPercent  Float?
  baseSaturationPercent Float?
  ctcCmolcDm3           Float?
  documentPath          String?
  documentFileName      String?
  notes                 String?
  createdById           String?
  createdAt             DateTime    @default(now())
}

enum TicketStatus {
  ABERTO
  EM_ANDAMENTO
  RESOLVIDO
  FECHADO
}

enum TicketPriority {
  BAIXA
  MEDIA
  ALTA
}

// Support ticket, scoped to the billing Account (not a Farm) since the customer
// side of a conversation may concern billing/plan issues unrelated to any one farm.
model Ticket {
  id          String          @id @default(uuid())
  account     Account         @relation(fields: [accountId], references: [id])
  accountId   String
  createdBy   User            @relation("TicketCreatedBy", fields: [createdById], references: [id])
  createdById String
  subject     String
  status      TicketStatus    @default(ABERTO)
  priority    TicketPriority  @default(MEDIA)
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  // True when written by platform staff (admin) replying — drives styling on the
  // customer-facing thread so it's visually obvious who said what.
  fromStaff Boolean  @default(false)
  message   String
  createdAt DateTime @default(now())
}

// Singleton row (id is always "mercadopago") holding the platform's Mercado Pago
// credentials when configured from the admin UI instead of the MERCADOPAGO_ACCESS_TOKEN
// env var. accessToken is encrypted at rest via EncryptionService — see
// MercadoPagoService for the env-var-vs-DB precedence and decryption.
model PlatformSetting {
  id            String   @id @default("mercadopago")
  accessToken   String?
  publicKey     String?
  webhookSecret String?
  updatedAt     DateTime @updatedAt
}

// Singleton (id fixo) com a configuração da geração automática de notificações,
// editável pelo admin da plataforma. frequency é uma das chaves conhecidas
// (NotificationsService.FREQUENCY_CRON); enabled liga/desliga o cron.
model NotificationSetting {
  id        String   @id @default("default")
  frequency String   @default("HOURLY")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

enum MercadoPagoLogEvent {
  CREATE_SUBSCRIPTION
  CANCEL_SUBSCRIPTION
  WEBHOOK
  PAYMENT_HISTORY_FETCH
  CONFIG_UPDATED
}

model MercadoPagoLog {
  id            String              @id @default(uuid())
  event         MercadoPagoLogEvent
  preapprovalId String?
  success       Boolean
  message       String
  createdAt     DateTime            @default(now())

  @@index([createdAt])
}
