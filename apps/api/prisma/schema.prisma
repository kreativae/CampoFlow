// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}

enum Role {
  OWNER
  MANAGER
  VETERINARIAN
  EMPLOYEE
  CONSULTANT
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String
  name             String
  refreshTokenHash String?
  memberships      Membership[]
  assignedTasks    Task[]       @relation("TaskAssignee")
  workLogs         WorkLog[]
  shifts           Shift[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum FarmType {
  FAZENDA
  SITIO
  CHACARA
  CONFINAMENTO
  ARRENDAMENTO
}

model Farm {
  id                 String          @id @default(uuid())
  name               String
  type               FarmType        @default(FAZENDA)
  totalAreaHectares  Float?
  usableAreaHectares Float?
  latitude           Float?
  longitude          Float?
  registryNumber     String?
  technicalManager   String?
  memberships        Membership[]
  pastures           Pasture[]
  animals            Animal[]
  transactions       Transaction[]
  weatherRecords     WeatherRecord[]
  supplies           Supply[]
  machines           Machine[]
  tasks              Task[]
  workLogs           WorkLog[]
  shifts             Shift[]
  agendaEvents       AgendaEvent[]
  mapFeatures        MapFeature[]
  documents          Document[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Membership {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  farmId    String
  role      Role
  createdAt DateTime @default(now())

  @@unique([userId, farmId])
}

model Pasture {
  id             String              @id @default(uuid())
  farm           Farm                @relation(fields: [farmId], references: [id])
  farmId         String
  name           String
  areaHectares   Float
  grassType      String?
  animalCapacity Int
  occupations    PastureOccupation[]
  animals        Animal[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Tracks a batch of animals occupying a pasture between rotations (history of occupation).
model PastureOccupation {
  id        String    @id @default(uuid())
  pasture   Pasture   @relation(fields: [pastureId], references: [id])
  pastureId String
  headCount Int
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  notes     String?
}

enum AnimalSex {
  MALE
  FEMALE
}

enum AnimalCategory {
  BEZERRO
  BEZERRA
  NOVILHO
  NOVILHA
  GARROTE
  BOI
  VACA
  TOURO
  MATRIZ
}

model Animal {
  id                 String              @id @default(uuid())
  farm               Farm                @relation(fields: [farmId], references: [id])
  farmId             String
  pasture            Pasture?            @relation(fields: [pastureId], references: [id])
  pastureId          String?
  earTag             String
  rfid               String?
  name               String?
  sex                AnimalSex
  breed              String?
  category           AnimalCategory
  birthDate          DateTime?
  currentWeightKg    Float?
  active             Boolean             @default(true)
  events             AnimalEvent[]
  vaccinations       VaccinationRecord[]
  treatments         TreatmentRecord[]
  weighings          WeighingRecord[]
  reproductiveEvents ReproductiveEvent[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([farmId, earTag])
}

enum AnimalEventType {
  TRANSFER
  WEIGHING
  VACCINATION
  TREATMENT
  REPRODUCTIVE
  SALE
  DEATH
}

// Generic event log for an animal's history; specialized records (weighing, vaccination, etc.)
// reference their own row by id and reuse this table for unified timeline queries.
model AnimalEvent {
  id          String          @id @default(uuid())
  animal      Animal          @relation(fields: [animalId], references: [id])
  animalId    String
  type        AnimalEventType
  occurredAt  DateTime        @default(now())
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
}

model VaccinationRecord {
  id             String    @id @default(uuid())
  animal         Animal    @relation(fields: [animalId], references: [id])
  animalId       String
  vaccineName    String
  scheduledDate  DateTime
  administeredAt DateTime?
  batchNumber    String?
  administeredBy String?
  notes          String?
  createdAt      DateTime  @default(now())
}

model TreatmentRecord {
  id             String   @id @default(uuid())
  animal         Animal   @relation(fields: [animalId], references: [id])
  animalId       String
  diagnosis      String?
  medication     String
  dosage         String?
  treatmentDate  DateTime @default(now())
  administeredBy String?
  notes          String?
  createdAt      DateTime @default(now())
}

model WeighingRecord {
  id        String   @id @default(uuid())
  animal    Animal   @relation(fields: [animalId], references: [id])
  animalId  String
  weightKg  Float
  weighedAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
}

enum ReproductiveEventType {
  IATF
  MONTA_NATURAL
  INSEMINACAO
  DIAGNOSTICO_PRENHEZ
  PARTO
  ABORTO
}

enum PregnancyDiagnosisResult {
  PRENHE
  VAZIA
}

model ReproductiveEvent {
  id        String                    @id @default(uuid())
  animal    Animal                    @relation(fields: [animalId], references: [id])
  animalId  String
  type      ReproductiveEventType
  eventDate DateTime                  @default(now())
  result    PregnancyDiagnosisResult?
  notes     String?
  createdAt DateTime                  @default(now())
}

enum TransactionType {
  RECEITA
  DESPESA
}

enum TransactionCategory {
  NUTRICAO
  MEDICAMENTOS
  FUNCIONARIOS
  COMBUSTIVEL
  MAQUINARIO
  ENERGIA
  VENDA_ANIMAL
  OUTROS
}

model Transaction {
  id          String              @id @default(uuid())
  farm        Farm                @relation(fields: [farmId], references: [id])
  farmId      String
  type        TransactionType
  category    TransactionCategory
  description String?
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// Records who changed what: every mutating request (POST/PATCH/PUT/DELETE) gets one row.
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String?
  method     String
  path       String
  statusCode Int
  createdAt  DateTime @default(now())
}

enum Commodity {
  BOI_GORDO
  VACA_GORDA
  NOVILHA
  BEZERRO
  REPOSICAO
  COURO
  SEBO
  LEITE
  MILHO
  SOJA
  SORGO
  FARELO_SOJA
}

// Market price reference data, shared across all farms (not tenant-scoped).
// MVP supports manual entry; automatic ingestion from external sources
// (Scot Consultoria, CEPEA, B3) is a future integration, not implemented yet.
model Quotation {
  id          String    @id @default(uuid())
  commodity   Commodity
  price       Float
  unit        String
  source      String?
  recordedAt  DateTime  @default(now())
  createdById String?
  createdAt   DateTime  @default(now())
}

enum WeatherAlertType {
  GEADA
  TEMPESTADE
  GRANIZO
  SECA
  VENTO_FORTE
}

// Farm-specific weather conditions. MVP supports manual entry; automatic ingestion
// from external providers (OpenWeather, Tomorrow.io, Climatempo) is a future integration.
model WeatherRecord {
  id              String            @id @default(uuid())
  farm            Farm              @relation(fields: [farmId], references: [id])
  farmId          String
  temperatureC    Float?
  humidityPercent Float?
  windSpeedKmh    Float?
  pressureHpa     Float?
  rainfallMm      Float?
  alertType       WeatherAlertType?
  notes           String?
  recordedAt      DateTime          @default(now())
  createdAt       DateTime          @default(now())
}

enum SupplyCategory {
  SAL_MINERAL
  RACAO
  FERTILIZANTE
  HERBICIDA
  DEFENSIVO
  OUTROS
}

enum SupplyMovementType {
  ENTRADA
  SAIDA
}

model Supply {
  id              String           @id @default(uuid())
  farm            Farm             @relation(fields: [farmId], references: [id])
  farmId          String
  name            String
  category        SupplyCategory
  unit            String
  currentQuantity Float            @default(0)
  minimumQuantity Float            @default(0)
  expirationDate  DateTime?
  notes           String?
  movements       SupplyMovement[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// Stock entries/exits; Supply.currentQuantity is kept in sync transactionally on each movement.
model SupplyMovement {
  id         String             @id @default(uuid())
  supply     Supply             @relation(fields: [supplyId], references: [id])
  supplyId   String
  type       SupplyMovementType
  quantity   Float
  notes      String?
  occurredAt DateTime           @default(now())
  createdAt  DateTime           @default(now())
}

enum MachineType {
  TRATOR
  CAMINHAO
  IMPLEMENTO
  OUTRO
}

model Machine {
  id               String               @id @default(uuid())
  farm             Farm                 @relation(fields: [farmId], references: [id])
  farmId           String
  name             String
  type             MachineType
  brand            String?
  model            String?
  year             Int?
  currentHourMeter Float                @default(0)
  notes            String?
  maintenances     MachineMaintenance[]
  fuelRecords      MachineFuelRecord[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

// Machine.currentHourMeter is kept in sync when a higher reading is reported here.
model MachineMaintenance {
  id          String   @id @default(uuid())
  machine     Machine  @relation(fields: [machineId], references: [id])
  machineId   String
  description String
  cost        Float?
  hourMeterAt Float?
  performedAt DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

// Machine.currentHourMeter is kept in sync when a higher reading is reported here.
model MachineFuelRecord {
  id          String   @id @default(uuid())
  machine     Machine  @relation(fields: [machineId], references: [id])
  machineId   String
  liters      Float
  cost        Float?
  hourMeterAt Float?
  recordedAt  DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model Task {
  id           String     @id @default(uuid())
  farm         Farm       @relation(fields: [farmId], references: [id])
  farmId       String
  title        String
  description  String?
  assignedTo   User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  status       TaskStatus @default(PENDENTE)
  dueDate      DateTime?
  completedAt  DateTime?
  workLogs     WorkLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Apontamento: hours a team member worked, optionally tied to a specific task.
model WorkLog {
  id          String   @id @default(uuid())
  farm        Farm     @relation(fields: [farmId], references: [id])
  farmId      String
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  task        Task?    @relation(fields: [taskId], references: [id])
  taskId      String?
  description String
  hoursWorked Float
  workDate    DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

// Escala: a team member's assigned working period.
model Shift {
  id        String   @id @default(uuid())
  farm      Farm     @relation(fields: [farmId], references: [id])
  farmId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
}

enum AgendaEventType {
  VACINACAO
  PESAGEM
  MANEJO
  COMPRA
  VENDA
  OUTRO
}

// General-purpose farm calendar. Vaccination/weighing already have dedicated flows
// elsewhere (health-records, weighings); this covers manejo/compra/venda and any
// ad-hoc reminder that doesn't have its own module.
model AgendaEvent {
  id            String          @id @default(uuid())
  farm          Farm            @relation(fields: [farmId], references: [id])
  farmId        String
  title         String
  type          AgendaEventType
  scheduledDate DateTime
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum MapFeatureType {
  CERCA
  PASTAGEM
  NASCENTE
  RESERVA
  OUTRO
}

enum GeometryType {
  PONTO
  POLIGONO
}

// Farm map features (cercas, pastagens, nascentes, reservas). Coordinates are stored as
// JSON: a single [lat, lng] pair for PONTO, or an array of [lat, lng] pairs for POLIGONO.
// Rendered client-side with Leaflet + OpenStreetMap (no API key required), since
// Google Maps/Mapbox would need paid API credentials not available in this environment.
model MapFeature {
  id           String         @id @default(uuid())
  farm         Farm           @relation(fields: [farmId], references: [id])
  farmId       String
  name         String
  type         MapFeatureType
  geometryType GeometryType
  coordinates  Json
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

enum DocumentCategory {
  GTA
  NFE
  CONTRATO
  EXAME
  CERTIFICADO
  OUTRO
}

// File metadata; the binary itself is stored on local disk under apps/api/uploads
// (storagePath). A future iteration can swap this for AWS S3 / Cloudflare R2 without
// changing this model, since storagePath is just an opaque reference to the file.
model Document {
  id           String           @id @default(uuid())
  farm         Farm             @relation(fields: [farmId], references: [id])
  farmId       String
  category     DocumentCategory
  fileName     String
  mimeType     String
  fileSize     Int
  storagePath  String
  uploadedById String?
  notes        String?
  createdAt    DateTime         @default(now())
}
