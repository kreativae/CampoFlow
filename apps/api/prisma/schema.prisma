// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}

enum Role {
  OWNER
  MANAGER
  VETERINARIAN
  EMPLOYEE
  CONSULTANT
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String
  name             String
  refreshTokenHash String?
  memberships      Membership[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum FarmType {
  FAZENDA
  SITIO
  CHACARA
  CONFINAMENTO
  ARRENDAMENTO
}

model Farm {
  id                 String       @id @default(uuid())
  name               String
  type               FarmType     @default(FAZENDA)
  totalAreaHectares  Float?
  usableAreaHectares Float?
  latitude           Float?
  longitude          Float?
  registryNumber     String?
  technicalManager   String?
  memberships        Membership[]
  pastures           Pasture[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Membership {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  farmId    String
  role      Role
  createdAt DateTime @default(now())

  @@unique([userId, farmId])
}

model Pasture {
  id             String              @id @default(uuid())
  farm           Farm                @relation(fields: [farmId], references: [id])
  farmId         String
  name           String
  areaHectares   Float
  grassType      String?
  animalCapacity Int
  occupations    PastureOccupation[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Tracks a batch of animals occupying a pasture between rotations (history of occupation).
model PastureOccupation {
  id        String    @id @default(uuid())
  pasture   Pasture   @relation(fields: [pastureId], references: [id])
  pastureId String
  headCount Int
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  notes     String?
}
