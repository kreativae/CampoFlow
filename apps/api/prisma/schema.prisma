// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}

enum Role {
  OWNER
  MANAGER
  VETERINARIAN
  EMPLOYEE
  CONSULTANT
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String
  name             String
  refreshTokenHash String?
  memberships      Membership[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum FarmType {
  FAZENDA
  SITIO
  CHACARA
  CONFINAMENTO
  ARRENDAMENTO
}

model Farm {
  id                 String       @id @default(uuid())
  name               String
  type               FarmType     @default(FAZENDA)
  totalAreaHectares  Float?
  usableAreaHectares Float?
  latitude           Float?
  longitude          Float?
  registryNumber     String?
  technicalManager   String?
  memberships        Membership[]
  pastures           Pasture[]
  animals            Animal[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Membership {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  farmId    String
  role      Role
  createdAt DateTime @default(now())

  @@unique([userId, farmId])
}

model Pasture {
  id             String              @id @default(uuid())
  farm           Farm                @relation(fields: [farmId], references: [id])
  farmId         String
  name           String
  areaHectares   Float
  grassType      String?
  animalCapacity Int
  occupations    PastureOccupation[]
  animals        Animal[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Tracks a batch of animals occupying a pasture between rotations (history of occupation).
model PastureOccupation {
  id        String    @id @default(uuid())
  pasture   Pasture   @relation(fields: [pastureId], references: [id])
  pastureId String
  headCount Int
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  notes     String?
}

enum AnimalSex {
  MALE
  FEMALE
}

enum AnimalCategory {
  BEZERRO
  BEZERRA
  NOVILHO
  NOVILHA
  GARROTE
  BOI
  VACA
  TOURO
  MATRIZ
}

model Animal {
  id                 String              @id @default(uuid())
  farm               Farm                @relation(fields: [farmId], references: [id])
  farmId             String
  pasture            Pasture?            @relation(fields: [pastureId], references: [id])
  pastureId          String?
  earTag             String
  rfid               String?
  name               String?
  sex                AnimalSex
  breed              String?
  category           AnimalCategory
  birthDate          DateTime?
  currentWeightKg    Float?
  active             Boolean             @default(true)
  events             AnimalEvent[]
  vaccinations       VaccinationRecord[]
  treatments         TreatmentRecord[]
  weighings          WeighingRecord[]
  reproductiveEvents ReproductiveEvent[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([farmId, earTag])
}

enum AnimalEventType {
  TRANSFER
  WEIGHING
  VACCINATION
  TREATMENT
  REPRODUCTIVE
  SALE
  DEATH
}

// Generic event log for an animal's history; specialized records (weighing, vaccination, etc.)
// reference their own row by id and reuse this table for unified timeline queries.
model AnimalEvent {
  id          String          @id @default(uuid())
  animal      Animal          @relation(fields: [animalId], references: [id])
  animalId    String
  type        AnimalEventType
  occurredAt  DateTime        @default(now())
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
}

model VaccinationRecord {
  id             String    @id @default(uuid())
  animal         Animal    @relation(fields: [animalId], references: [id])
  animalId       String
  vaccineName    String
  scheduledDate  DateTime
  administeredAt DateTime?
  batchNumber    String?
  administeredBy String?
  notes          String?
  createdAt      DateTime  @default(now())
}

model TreatmentRecord {
  id             String   @id @default(uuid())
  animal         Animal   @relation(fields: [animalId], references: [id])
  animalId       String
  diagnosis      String?
  medication     String
  dosage         String?
  treatmentDate  DateTime @default(now())
  administeredBy String?
  notes          String?
  createdAt      DateTime @default(now())
}

model WeighingRecord {
  id        String   @id @default(uuid())
  animal    Animal   @relation(fields: [animalId], references: [id])
  animalId  String
  weightKg  Float
  weighedAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
}

enum ReproductiveEventType {
  IATF
  MONTA_NATURAL
  INSEMINACAO
  DIAGNOSTICO_PRENHEZ
  PARTO
  ABORTO
}

enum PregnancyDiagnosisResult {
  PRENHE
  VAZIA
}

model ReproductiveEvent {
  id        String                    @id @default(uuid())
  animal    Animal                    @relation(fields: [animalId], references: [id])
  animalId  String
  type      ReproductiveEventType
  eventDate DateTime                  @default(now())
  result    PregnancyDiagnosisResult?
  notes     String?
  createdAt DateTime                  @default(now())
}
